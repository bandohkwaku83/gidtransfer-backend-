PORT=7100
NODE_ENV=development

MONGO_URL=mongodb://127.0.0.1:27017/photo_global_database
# Optional MongoDB connection pool tuning
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=2
# MONGO_MAX_IDLE_MS=30000
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGO_SOCKET_TIMEOUT_MS=45000

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Cache authenticated user/admin lookups (ms, default 60000)
# AUTH_CACHE_TTL_MS=60000
# Cache gallery tab counts per owner (ms, default 30000)
# GALLERY_COUNTS_CACHE_TTL_MS=30000

# Log requests slower than this threshold (ms, default 200)
# SLOW_REQUEST_MS=200
# Set to 0 to disable Server-Timing response header
# REQUEST_TIMING_HEADER=1
# Minimum response size before gzip compression (bytes, default 1024)
# COMPRESSION_THRESHOLD_BYTES=1024

# Incremental sync + realtime (frontend round-trip optimization)
# SYNC_REVISION_CACHE_TTL_MS=5000
# SYNC_CHANGES_LIMIT=200
# SSE_HEARTBEAT_MS=25000

# Client app URL (gallery share links)
APP_URL=http://localhost:3000

# Google OAuth — must match NEXT_PUBLIC_GOOGLE_CLIENT_ID in the Next app
GOOGLE_CLIENT_ID=

# Comma-separated list for production (e.g. http://localhost:3000,https://admin.example.com)
CORS_ORIGINS=

# OpenAI — optional gallery AI descriptions
OPENAI_API_KEY=

# Arkesel SMS — platform account; each studio uses its own approved sender ID
ARKESEL_API_KEY=
ARKESEL_DEFAULT_SENDER=Gidtransfer
# Optional: log SMS instead of sending (development)
# ARKESEL_SMS_DRY_RUN=true
# ARKESEL_API_URL=https://sms.arkesel.com/api/v2/sms/send

# Resend email — photographer notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Gidtransfer <notifications@yourdomain.com>
# Email logo: image/email-logo.png
# Production: set API_PUBLIC_URL to your public HTTPS API (e.g. https://api.gidtransfer.com)
# so email clients can load /image/email-logo.png
API_PUBLIC_URL=http://127.0.0.1:7100
# RESEND_FROM_NAME=Gidtransfer
# RESEND_EMAIL_DRY_RUN=true  # skips notification emails only; OTP + password reset still send
# EMAIL_NOTIFICATIONS_ENABLED=true
# BOOKING_DAY_REMINDER_HOURS_BEFORE=24
# BOOKING_HOUR_REMINDER_HOURS_BEFORE=1
# BOOKING_REMINDER_CHECK_MINUTES=15

# Paystack — subscription billing (GHS)
PAYSTACK_SECRET_KEY=sk_test_beb8549e1c0dc1f5e23dc020ecbc5f6f5a54da97
PAYSTACK_PUBLIC_KEY=pk_test_ebd7e92295ca43cc816bcee5e85f8c50b909368d
# Run `node scripts/createPaystackPlans.js` after adding PAYSTACK_SECRET_KEY,
# then paste the plan codes Paystack returns:
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_PRO=
PAYSTACK_PLAN_STUDIO=
# Optional: post-payment redirect (default: APP_URL/billing/callback)
# PAYSTACK_CALLBACK_URL=http://localhost:3000/billing/callback

# AWS S3 — direct-to-bucket uploads (gallery photos & finals bypass the server)
# When configured, clients must use presign → PUT to S3 → complete (see API docs).
# Configure bucket CORS to allow PUT from your frontend origin.
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: parallel thumbnail/watermark jobs after S3 upload (default 2)
# DERIVATIVE_QUEUE_CONCURRENCY=2
# Max longest edge for grid thumbnails in px (default 1200; originals are never resized)
# GALLERY_THUMB_MAX_PX=1200
# Optional: CloudFront or custom CDN base URL for public reads (no trailing slash)
# S3_PUBLIC_URL=https://cdn.example.com
