# =============================================================================
# BACKEND ONLY — photo_global_backend (API server)
# =============================================================================
# Copy to .env in THIS repo.
#
# Frontend .env files live in OTHER repos:
#   docs/env.main-frontend.example  → gidtransfer.com (photographers)
#   docs/env.admin-frontend.example → admin.gidtransfer.com (platform staff)
# =============================================================================

PORT=7100
NODE_ENV=development

MONGO_URL=mongodb://127.0.0.1:27017/photo_global_database
# Optional MongoDB connection pool tuning
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=2
# MONGO_MAX_IDLE_MS=30000
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGO_SOCKET_TIMEOUT_MS=45000

# -----------------------------------------------------------------------------
# Auth (backend only — never expose in frontend .env)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Cache authenticated user/admin lookups (ms, default 60000)
# AUTH_CACHE_TTL_MS=60000
# Cache gallery tab counts per owner (ms, default 30000)
# GALLERY_COUNTS_CACHE_TTL_MS=30000

# -----------------------------------------------------------------------------
# Frontend URLs (backend references — NOT the frontend .env files)
# -----------------------------------------------------------------------------
# MAIN app public URL: emails, gallery share links, password reset, Paystack callback
APP_URL=http://localhost:3000
# Production: https://gidtransfer.com

# Public HTTPS URL of THIS API (email images, absolute media links)
API_PUBLIC_URL=http://127.0.0.1:7100
# Production: https://api.gidtransfer.com

# Browser origins allowed to call this API (REQUIRED in production).
# List BOTH frontends — main app AND admin app:
CORS_ORIGINS=
# Production example:
# CORS_ORIGINS=https://gidtransfer.com,https://www.gidtransfer.com,https://admin.gidtransfer.com

# Google OAuth — must match NEXT_PUBLIC_GOOGLE_CLIENT_ID in MAIN frontend only
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Admin user seed (backend only — `node scripts/createAdmin.js`)
# NOT for the admin frontend .env
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_NAME=Platform Admin

# -----------------------------------------------------------------------------
# Performance / sync (backend tuning)
# -----------------------------------------------------------------------------
# Log requests slower than this threshold (ms, default 200)
# SLOW_REQUEST_MS=200
# Set to 0 to disable Server-Timing response header
# REQUEST_TIMING_HEADER=1
# Minimum response size before gzip compression (bytes, default 1024)
# COMPRESSION_THRESHOLD_BYTES=1024
# SYNC_REVISION_CACHE_TTL_MS=5000
# SYNC_CHANGES_LIMIT=200
# SSE_HEARTBEAT_MS=25000

# -----------------------------------------------------------------------------
# Integrations (backend only)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

ARKESEL_API_KEY=
ARKESEL_DEFAULT_SENDER=Gidtransfer
# ARKESEL_SMS_DRY_RUN=true
# ARKESEL_API_URL=https://sms.arkesel.com/api/v2/sms/send

RESEND_API_KEY=
RESEND_FROM_EMAIL=Gidtransfer <notifications@yourdomain.com>
# RESEND_FROM_NAME=Gidtransfer
# RESEND_EMAIL_DRY_RUN=true
# EMAIL_NOTIFICATIONS_ENABLED=true
# BOOKING_DAY_REMINDER_HOURS_BEFORE=24
# BOOKING_HOUR_REMINDER_HOURS_BEFORE=1
# BOOKING_REMINDER_CHECK_MINUTES=15

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Run `node scripts/createPaystackPlans.js` after adding PAYSTACK_SECRET_KEY:
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_PRO=
PAYSTACK_PLAN_STUDIO=
# Optional: post-payment redirect (default: APP_URL/billing/callback)
# PAYSTACK_CALLBACK_URL=http://localhost:3000/billing/callback

S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3 bucket CORS must allow PUT from MAIN frontend origin (gidtransfer.com)
# DERIVATIVE_QUEUE_CONCURRENCY=2
# GALLERY_THUMB_MAX_PX=1200
# S3_PUBLIC_URL=https://cdn.example.com
