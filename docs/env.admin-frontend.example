# =============================================================================
# ADMIN FRONTEND ONLY — separate admin app (platform staff)
# =============================================================================
# Copy to .env.local in the ADMIN Next.js repo (separate project).
# Do NOT put these in photo_global_backend/.env
# =============================================================================

# Backend API (no trailing slash) — same server as the main app
NEXT_PUBLIC_API_URL=http://127.0.0.1:7100
# Production: https://api.gidtransfer.com

# Optional: this admin app's own URL (canonical links, CORS origin in production)
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# NOT needed in the admin frontend .env:
# - GOOGLE_CLIENT_ID / NEXT_PUBLIC_GOOGLE_CLIENT_ID (photographer OAuth is main app only)
# - APP_URL (backend uses that for photographer emails and billing — gidtransfer.com)
# - JWT_SECRET, MONGO_URL, or any API keys (backend only)
# - ADMIN_EMAIL, ADMIN_PASSWORD (used by backend `node scripts/createAdmin.js` only)
# - CORS_ORIGINS (backend only — add this app's origin alongside gidtransfer.com)
# -----------------------------------------------------------------------------
