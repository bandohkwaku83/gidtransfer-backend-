# =============================================================================
# MAIN FRONTEND ONLY — gidtransfer.com (photographer app)
# =============================================================================
# Copy to .env.local in the MAIN Next.js repo.
# Do NOT put these in photo_global_backend/.env
# =============================================================================

# Backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://127.0.0.1:7100
# Production: https://api.gidtransfer.com

# This app's public URL (OAuth redirects, billing callback route, canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://gidtransfer.com

# Must match GOOGLE_CLIENT_ID in photo_global_backend/.env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# NOT needed in the main frontend .env (handled by the backend):
# - JWT_SECRET, MONGO_URL, RESEND_API_KEY, ARKESEL_API_KEY, AWS_*, PAYSTACK_SECRET_KEY
# - PAYSTACK_PUBLIC_KEY (frontend loads it from GET /api/billing/config)
# - ADMIN_EMAIL, ADMIN_PASSWORD (backend script only)
# - CORS_ORIGINS (backend only — list gidtransfer.com and your admin app origin)
# -----------------------------------------------------------------------------
